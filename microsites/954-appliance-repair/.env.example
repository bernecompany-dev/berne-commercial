# --- 954 Appliance Repair — environment ---
# Copy to .env.local for local dev; set these in the Vercel project for prod.

# Resend transport for the lead form (own key, separate from other brands)
RESEND_API_KEY=
# From address must be on a Resend-verified domain for this brand
DISPATCH_FROM_EMAIL=leads@954appliancerepair.com
# All leads land in the shared Berne inbox; subject + UTM tag the source
DISPATCH_TO_EMAIL=bernerepair@gmail.com

# Public site URL (no trailing slash) — used for canonical + JSON-LD @id
NEXT_PUBLIC_SITE_URL=https://954appliancerepair.com

# Analytics — NEW ids for this brand only (do not reuse Berne ids)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=

# Brand phone (swap for a 954 CallRail tracking number; falls back to dispatch)
NEXT_PUBLIC_PHONE=(754) 345-4515
